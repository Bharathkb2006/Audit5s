# Copy to .env.local for local dev. In Vercel: Project → Settings → Environment Variables (same names).
# Values come from Firebase Console → Project settings → Your apps → Web app config.

REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=

# Optional — enables Firebase Analytics (same as measurementId in Firebase console)
REACT_APP_FIREBASE_MEASUREMENT_ID=

# Admin login is app-only (admin / admin123). Leave false; Firebase Auth is not used.
REACT_APP_FIREBASE_USE_AUTH=false
